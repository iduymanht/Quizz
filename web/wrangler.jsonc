{
	"compatibility_date": "2026-06-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "Quiz-web",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"routes": [
		{ "pattern": "Quiz.thenightwatcher.online", "custom_domain": true }
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "Quiz-web",
			"database_id": "13b5de60-5ac0-46bd-b493-5d5138309f6a"
		}
	],
	"r2_buckets": [
		{
			"binding": "PETS",
			"bucket_name": "Quiz-petcache"
		}
	],
	"observability": {
		"enabled": true
	}
}