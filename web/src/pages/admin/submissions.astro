---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { adminUser } from "../../lib/admin";

export const prerender = false;
const user = await adminUser(Astro.cookies);
---
<Base title="Submissions · Admin · AgentPet" description="Review community pet submissions." active="">
  {!user ? (
    <section class="px-4 py-24">
      <div class="card mx-auto max-w-md p-8 text-center">
        <h1 class="font-display text-2xl font-bold text-ink">Admin only</h1>
        <a href="/api/auth/login?returnTo=/admin/submissions" class="btn-primary mt-6 !px-6 !py-3"><Icon name="users" class="h-5 w-5" /> Sign in</a>
      </div>
    </section>
  ) : (
    <section class="px-4 pt-8 pb-16">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-2">
          <a href="/admin" class="grid h-8 w-8 place-items-center rounded-full border border-line bg-white text-muted hover:border-brand-300 hover:text-brand-700"><Icon name="arrow" class="h-4 w-4 rotate-180" /></a>
          <h1 class="font-display text-2xl font-bold text-ink">Submission queue</h1>
          <div id="tabs" class="ml-auto flex gap-2">
            <button data-status="pending" class="chip chip-active !px-3 !py-1 text-xs">Pending</button>
            <button data-status="approved" class="chip !px-3 !py-1 text-xs">Approved</button>
            <button data-status="rejected" class="chip !px-3 !py-1 text-xs">Rejected</button>
          </div>
        </div>
        <p class="mt-2 text-sm text-muted"><span id="count">Loading…</span></p>
        <div id="list" class="mt-4 grid gap-4 sm:grid-cols-2"></div>
        <div id="empty" class="hidden py-16 text-center text-muted">Nothing here.</div>
      </div>
    </section>

    <!-- Detail modal: opens when a submission card is clicked. -->
    <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
      <div class="card max-h-[90vh] w-full max-w-lg overflow-auto p-0" id="modal-card">
        <div id="modal-body"></div>
      </div>
    </div>

    <script>
      const esc = (s: string) => String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
      const listEl = document.getElementById("list")!;
      const countEl = document.getElementById("count")!;
      const emptyEl = document.getElementById("empty")!;
      const modal = document.getElementById("modal")!;
      const modalBody = document.getElementById("modal-body")!;
      let status = "pending";
      let subsById: Record<string, any> = {};
      let animTimer: number | null = null;

      // Slices a spritesheet's first (idle) row into frames via alpha gutters,
      // the same way the app does, so we can animate it instead of showing a
      // static sheet.
      function seg(a: boolean[]) {
        const r: [number, number][] = []; let s: number | null = null;
        for (let i = 0; i < a.length; i++) { if (a[i] && s === null) s = i; else if (!a[i] && s !== null) { r.push([s, i]); s = null; } }
        if (s !== null) r.push([s, a.length]); return r;
      }
      function sliceFirstRow(img: HTMLImageElement): { x: number; y: number; w: number; h: number }[] | null {
        const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
        const off = document.createElement("canvas"); off.width = w; off.height = h;
        const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
        let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
        const rowHas: boolean[] = new Array(h).fill(false);
        for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
        const rows = seg(rowHas); if (!rows.length) return null;
        const [y0, y1] = rows[0];
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) { for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; } }
        const cols = seg(colHas);
        return cols.map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
      }
      function stopAnim() { if (animTimer !== null) { clearInterval(animTimer); animTimer = null; } }
      function startAnim(url: string) {
        stopAnim();
        const cv = document.getElementById("sub-anim") as HTMLCanvasElement | null;
        if (!cv) return;
        const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
        const img = new Image();
        img.onload = () => {
          const frames = sliceFirstRow(img);
          if (!frames || !frames.length) return;
          let i = 0;
          const draw = () => {
            const f = frames[i % frames.length];
            const sc = Math.min(cv.width / f.w, cv.height / f.h) * 0.9, dw = f.w * sc, dh = f.h * sc;
            ctx.clearRect(0, 0, cv.width, cv.height);
            ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
            i++;
          };
          draw();
          if (frames.length > 1) animTimer = window.setInterval(draw, 1000 / 6);
        };
        img.src = url;
      }

      function actionsHtml(s: any) {
        return s.status === "pending"
          ? `<div class="flex gap-2">
               <button data-approve="${s.id}" class="btn-primary !px-4 !py-2 text-sm flex-1">Approve</button>
               <button data-reject="${s.id}" class="chip !border-rose-200 !text-rose-600 !px-4 !py-2 text-sm">Reject</button>
             </div>`
          : `<div class="text-xs font-semibold ${s.status === "approved" ? "text-emerald-600" : "text-rose-600"} uppercase">${s.status}</div>`;
      }

      function card(s: any) {
        return `<div data-row="${s.id}" class="card cursor-pointer overflow-hidden p-0 transition hover:-translate-y-0.5">
          <div class="grid place-items-center border-b border-line p-4 sprite-checker"><img src="${s.previewUrl}" alt="" class="pixel-art max-h-48" loading="lazy" /></div>
          <div class="p-4">
            <div class="flex items-baseline justify-between gap-2">
              <span class="truncate font-display text-lg font-semibold text-ink">${esc(s.name)}</span>
              <span class="shrink-0 font-pixel text-[10px] uppercase tracking-wide text-faint">${esc(s.kind)}</span>
            </div>
            <div class="mt-0.5 text-xs text-faint">by ${esc(s.login)} · ${esc(s.slug)}</div>
            ${s.description ? `<p class="mt-1 line-clamp-2 text-xs text-muted">${esc(s.description)}</p>` : ""}
            <div class="mt-3">${actionsHtml(s)}</div>
          </div>
        </div>`;
      }

      // Full review detail in a modal: big sprite, all metadata, approve/reject.
      function openDetail(id: string) {
        const s = subsById[id]; if (!s) return;
        const when = s.created_at ? new Date(s.created_at).toLocaleString() : "";
        modalBody.innerHTML = `
          <div class="border-b border-line p-6 sprite-checker">
            <div class="grid place-items-center">
              <canvas id="sub-anim" width="240" height="240" class="pixel-art h-44 w-44"></canvas>
            </div>
            <div class="mt-2 text-center text-[11px] text-faint">Idle animation · full spritesheet below</div>
            <img src="${s.previewUrl}" alt="" class="pixel-art mx-auto mt-2 max-h-44 opacity-90" />
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="truncate font-display text-xl font-bold text-ink">${esc(s.name)}</div>
                <div class="mt-0.5 text-xs text-faint">${esc(s.slug)} · <span class="uppercase">${esc(s.kind)}</span></div>
              </div>
              <button id="modal-close" class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-line text-muted hover:text-ink">✕</button>
            </div>
            <div class="mt-3 flex items-center gap-2 text-sm text-muted">
              ${s.avatar ? `<img src="${esc(s.avatar)}" alt="" class="h-6 w-6 rounded-full" />` : ""}
              <span>by <b class="text-ink">${esc(s.login)}</b></span>
              ${when ? `<span class="text-faint">· ${esc(when)}</span>` : ""}
            </div>
            ${s.description ? `<p class="mt-3 text-sm text-muted">${esc(s.description)}</p>` : ""}
            <a href="${s.previewUrl}" target="_blank" rel="noopener" class="mt-3 inline-block text-xs font-semibold text-brand-600 hover:text-brand-700">Open full spritesheet ↗</a>
            <div class="mt-5">${actionsHtml(s)}</div>
          </div>`;
        modal.classList.remove("hidden"); modal.classList.add("flex");
        startAnim(s.previewUrl);
      }
      function closeModal() { stopAnim(); modal.classList.add("hidden"); modal.classList.remove("flex"); }

      function refreshCount() {
        const n = Object.keys(subsById).length;
        countEl.textContent = `${n} ${status}`;
        emptyEl.classList.toggle("hidden", n > 0);
      }

      async function doAction(id: string, action: string, btn?: HTMLButtonElement) {
        if (btn) btn.disabled = true;
        const r = await fetch("/api/admin/submission", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ id, action }) }).then((x) => x.json()).catch(() => null);
        if (r?.ok) {
          document.querySelector(`[data-row="${id}"]`)?.remove();
          delete subsById[id];
          closeModal();
          refreshCount();
        } else if (btn) { btn.disabled = false; }
      }

      async function load() {
        countEl.textContent = "Loading…"; listEl.innerHTML = "";
        const d: any = await fetch("/api/admin/submissions.json?status=" + status).then((r) => r.json()).catch(() => ({ submissions: [] }));
        const subs = d.submissions || [];
        subsById = {}; subs.forEach((s: any) => { subsById[s.id] = s; });
        refreshCount();
        listEl.innerHTML = subs.map(card).join("");
      }

      document.getElementById("tabs")!.addEventListener("click", (e) => {
        const b = (e.target as HTMLElement).closest("button"); if (!b) return;
        status = (b as HTMLElement).dataset.status!;
        document.querySelectorAll("#tabs button").forEach((x) => x.classList.remove("chip-active"));
        b.classList.add("chip-active"); load();
      });

      // Card: approve/reject inline, or click anywhere else to open the detail modal.
      listEl.addEventListener("click", (e) => {
        const t = e.target as HTMLElement;
        const ap = t.closest("[data-approve]") as HTMLElement | null;
        const rj = t.closest("[data-reject]") as HTMLElement | null;
        if (ap || rj) { doAction((ap?.dataset.approve || rj?.dataset.reject)!, ap ? "approve" : "reject", t as HTMLButtonElement); return; }
        const row = t.closest("[data-row]") as HTMLElement | null;
        if (row) openDetail(row.dataset.row!);
      });

      // Modal: backdrop / close button dismiss; approve/reject act.
      modal.addEventListener("click", (e) => {
        const t = e.target as HTMLElement;
        if (t === modal || t.closest("#modal-close")) { closeModal(); return; }
        const ap = t.closest("[data-approve]") as HTMLElement | null;
        const rj = t.closest("[data-reject]") as HTMLElement | null;
        if (ap || rj) doAction((ap?.dataset.approve || rj?.dataset.reject)!, ap ? "approve" : "reject", t as HTMLButtonElement);
      });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

      load();
    </script>
  )}
</Base>
