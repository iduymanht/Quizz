---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
---
<Base title="Lost in the clouds · AgentPet" description="That page floated off the island , page not found.">
  <section class="relative overflow-hidden px-4 pt-12 pb-24">
    <img src="/island/cloud2.png" alt="" class="pixel-art pointer-events-none absolute left-0 top-10 w-48 opacity-70" style="animation: drift 90s linear infinite" />
    <img src="/island/cloud4.png" alt="" class="pixel-art pointer-events-none absolute right-0 top-32 w-56 opacity-60" style="animation: drift 120s linear infinite -40s" />
    <img src="/island/cloud5.png" alt="" class="pixel-art pointer-events-none absolute left-1/4 bottom-10 w-40 opacity-50" style="animation: drift 150s linear infinite -80s" />

    <div class="relative z-10 mx-auto max-w-2xl text-center">
      <div class="relative mx-auto w-full max-w-sm">
        <canvas id="lostPet" class="bob pixel-art absolute left-1/2 top-2 z-20 h-24 w-24 -translate-x-1/2" width="160" height="160"></canvas>
        <img src="/island/main.png" alt="" class="bob-slow pixel-art relative z-10 mx-auto mt-16 w-full" style="filter: drop-shadow(0 26px 22px rgba(30,58,130,.26))" />
      </div>
      <div class="mt-6 font-pixel text-[12px] uppercase tracking-wide text-brand-500">Error 404</div>
      <h1 class="mt-2 font-display text-4xl font-bold text-ink sm:text-5xl">Lost in the clouds</h1>
      <p class="mx-auto mt-3 max-w-md text-muted">This page floated off the island. Let's get you back to solid ground.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary !px-6 !py-3"><Icon name="paw" class="h-5 w-5" /> Back home</a>
        <a href="/gallery" class="btn-ghost !px-6 !py-3"><Icon name="grid" class="h-5 w-5" /> Browse pets</a>
        <button id="surprise404" type="button" class="btn-ghost !px-6 !py-3"><Icon name="shuffle" class="h-5 w-5" /> Surprise me</button>
      </div>
    </div>
  </section>

  <script>
    type Frame = { x: number; y: number; w: number; h: number };
    function seg(a: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < a.length; i++) { if (a[i] && s === null) s = i; else if (!a[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, a.length]); return r; }
    function firstRow(img: HTMLImageElement): Frame[] | null {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rh: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rh[y] = true; break; } }
      const rows = seg(rh); if (!rows.length) return null; const [y0, y1] = rows[0];
      const ch: boolean[] = new Array(w).fill(false);
      for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { ch[x] = true; break; }
      return seg(ch).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
    }
    const cv = document.getElementById("lostPet") as HTMLCanvasElement;
    let randomSlug = "";
    (async () => {
      let d: any; try { d = await (await fetch("/api/random-pet.json")).json(); } catch { return; }
      if (!d?.slug) return; randomSlug = d.slug;
      const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
      const img = new Image();
      img.onload = () => {
        const fr = firstRow(img); if (!fr || !fr.length) return;
        let i = 0;
        const draw = (f: Frame) => { ctx.clearRect(0, 0, cv.width, cv.height); const s = Math.min(cv.width / f.w, cv.height / f.h) * 0.86, dw = f.w * s, dh = f.h * s; ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh); };
        draw(fr[0]); if (fr.length > 1) setInterval(() => { i = (i + 1) % fr.length; draw(fr[i]); }, 150);
      };
      img.src = "/api/sprite/" + d.slug;
    })();
    document.getElementById("surprise404")?.addEventListener("click", async () => {
      if (randomSlug) { location.href = "/pet/" + randomSlug; return; }
      try { const d: any = await (await fetch("/api/random-pet.json")).json(); if (d?.slug) location.href = "/pet/" + d.slug; } catch {}
    });
  </script>
</Base>
