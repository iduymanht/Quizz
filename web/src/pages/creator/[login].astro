---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { getDB, ensureSchema, getOverrides } from "../../lib/db";

export const prerender = false;

const { login = "" } = Astro.params;
if (!/^[a-z0-9][a-z0-9-]{0,38}$/i.test(login)) return Astro.rewrite("/404");

const db = getDB();
if (!db) return Astro.rewrite("/404");
await ensureSchema(db);
const ovr: any = await getOverrides(db);

const rows: any = await db
  .prepare("SELECT slug, name, kind, description, avatar, created_at FROM submissions WHERE login=? COLLATE NOCASE AND status='approved' ORDER BY created_at DESC")
  .bind(login).all();
let pets = (rows?.results ?? []).filter((p: any) => !ovr[p.slug]?.hidden);
if (!pets.length) return Astro.rewrite("/404");

// Prefer the override name when an admin renamed the pet.
pets = pets.map((p: any) => ({ ...p, name: ovr[p.slug]?.name || p.name }));
const realLogin = login; // keep the URL casing for the GitHub link
const avatar = pets.find((p: any) => p.avatar)?.avatar || "";
const count = pets.length;
---
<Base title={`${realLogin} · Creator · Quiz`} description={`Pets created by ${realLogin} on Quiz.`} active="leaderboard">
  <section class="px-4 pt-8 pb-16">
    <div class="mx-auto max-w-5xl">
      <a href="/leaderboard" class="inline-flex items-center gap-1 text-sm font-semibold text-muted transition hover:text-ink"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><path d="m15 18-6-6 6-6"/></svg> Back to leaderboard</a>

      <header class="card mt-4 flex flex-col items-center gap-4 p-6 text-center sm:flex-row sm:text-left">
        {avatar
          ? <img src={avatar} alt="" class="h-20 w-20 shrink-0 rounded-full border border-line" />
          : <span class="grid h-20 w-20 shrink-0 place-items-center rounded-full bg-emerald-50 text-2xl font-display font-bold text-emerald-600">{realLogin.charAt(0).toUpperCase()}</span>}
        <div class="min-w-0 flex-1">
          <h1 class="font-display text-2xl font-bold text-ink">{realLogin}</h1>
          <p class="mt-1 text-muted">{count} pet{count === 1 ? "" : "s"} in the gallery</p>
        </div>
        <a href={`https://github.com/${realLogin}`} target="_blank" rel="noopener" class="btn-ghost shrink-0 !px-4 !py-2 text-sm"><Icon name="github" class="h-4 w-4" /> GitHub</a>
      </header>

      <div id="pet-grid" class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {pets.map((p: any) => (
          <button data-slug={p.slug} data-name={p.name} data-kind={p.kind} class="pet-card card cursor-pointer overflow-hidden p-0 text-left transition hover:-translate-y-0.5 hover:border-brand-300">
            <span class="ap-skel grid aspect-square place-items-center border-b border-line p-3 sprite-checker">
              <canvas class="thumb h-full w-full" width="160" height="160" data-sheet={`/api/sprite/${p.slug}`}></canvas>
            </span>
            <span class="block p-3">
              <span class="block truncate font-display font-semibold text-ink">{p.name}</span>
              <span class="font-pixel text-[9px] uppercase tracking-wide text-faint">{p.kind}</span>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Pet detail modal: per-action animations + link to the full page. -->
  <div id="pet-modal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-ink/40 p-4 backdrop-blur-sm">
    <div class="card max-h-[88vh] w-full max-w-lg overflow-auto p-0">
      <div class="flex items-start justify-between gap-3 border-b border-line p-5">
        <div class="min-w-0">
          <div id="pm-name" class="truncate font-display text-xl font-bold text-ink"></div>
          <div id="pm-kind" class="mt-0.5 font-pixel text-[10px] uppercase tracking-wide text-faint"></div>
        </div>
        <button id="pm-close" type="button" class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-line text-muted hover:text-ink">✕</button>
      </div>
      <div class="p-5">
        <div class="mb-2 text-center text-[11px] font-semibold uppercase tracking-wide text-faint">Animations by action</div>
        <div id="pm-anims" class="grid grid-cols-3 gap-2 sm:grid-cols-4"></div>
        <a id="pm-link" href="#" target="_blank" rel="noopener" class="btn-primary mt-5 w-full !py-2.5 text-sm">View full page →</a>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const ACTION_NAMES = ["Idle", "Run Right", "Run Left", "Waving", "Jumping", "Failed", "Waiting", "Running", "Review"];
      type Frame = { x: number; y: number; w: number; h: number };
      function seg(a: boolean[]) {
        const r: [number, number][] = []; let s: number | null = null;
        for (let i = 0; i < a.length; i++) { if (a[i] && s === null) s = i; else if (!a[i] && s !== null) { r.push([s, i]); s = null; } }
        if (s !== null) r.push([s, a.length]); return r;
      }
      function sliceRows(img: HTMLImageElement): Frame[][] | null {
        const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
        const off = document.createElement("canvas"); off.width = w; off.height = h;
        const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
        let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
        const rowHas: boolean[] = new Array(h).fill(false);
        for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
        const rows: Frame[][] = [];
        for (const [y0, y1] of seg(rowHas)) {
          const colHas: boolean[] = new Array(w).fill(false);
          for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
          const fr = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
          if (fr.length) rows.push(fr);
        }
        return rows;
      }

      // Grid thumbnails: draw the first frame of each pet.
      document.querySelectorAll<HTMLCanvasElement>("canvas.thumb").forEach((cv) => {
        const img = new Image();
        img.onload = () => {
          const rows = sliceRows(img); if (!rows || !rows.length) return;
          const f = rows[0][0], ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
          const sc = Math.min(cv.width / f.w, cv.height / f.h) * 0.82, dw = f.w * sc, dh = f.h * sc;
          ctx.clearRect(0, 0, cv.width, cv.height);
          ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
          cv.parentElement?.classList.remove("ap-skel");
        };
        img.src = cv.dataset.sheet!;
      });

      // Modal animation player.
      const modal = document.getElementById("pet-modal")!;
      const anims = document.getElementById("pm-anims")!;
      let timer: number | null = null;
      const stop = () => { if (timer !== null) { clearInterval(timer); timer = null; } };
      function play(slug: string) {
        stop();
        const img = new Image();
        img.onload = () => {
          const rows = sliceRows(img);
          if (!rows || !rows.length) { anims.innerHTML = `<div class="col-span-full text-center text-sm text-faint">Could not load animations.</div>`; return; }
          anims.innerHTML = rows.map((_, r) => `
            <div class="rounded-xl border border-line p-2 sprite-checker text-center">
              <canvas data-anim="${r}" width="120" height="120" class="pixel-art mx-auto h-20 w-20"></canvas>
              <div class="mt-1 font-pixel text-[9px] uppercase tracking-wide text-faint">${ACTION_NAMES[r] || "Row " + (r + 1)}</div>
            </div>`).join("");
          const players = rows.map((frames, r) => {
            const cv = anims.querySelector(`canvas[data-anim="${r}"]`) as HTMLCanvasElement;
            const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
            return { cv, ctx, frames, i: 0 };
          });
          const tick = () => {
            for (const p of players) {
              const f = p.frames[p.i % p.frames.length];
              const sc = Math.min(p.cv.width / f.w, p.cv.height / f.h) * 0.9, dw = f.w * sc, dh = f.h * sc;
              p.ctx.clearRect(0, 0, p.cv.width, p.cv.height);
              p.ctx.drawImage(img, f.x, f.y, f.w, f.h, (p.cv.width - dw) / 2, (p.cv.height - dh) / 2, dw, dh);
              p.i++;
            }
          };
          tick();
          timer = window.setInterval(tick, 1000 / 6);
        };
        img.src = `/api/sprite/${slug}`;
      }
      function close() { modal.classList.add("hidden"); modal.classList.remove("flex"); stop(); }

      document.querySelectorAll<HTMLElement>(".pet-card").forEach((c) => {
        c.addEventListener("click", () => {
          const slug = c.dataset.slug!;
          (document.getElementById("pm-name") as HTMLElement).textContent = c.dataset.name || slug;
          (document.getElementById("pm-kind") as HTMLElement).textContent = c.dataset.kind || "";
          (document.getElementById("pm-link") as HTMLAnchorElement).href = `/pet/${slug}`;
          anims.innerHTML = "";
          modal.classList.remove("hidden"); modal.classList.add("flex");
          play(slug);
        });
      });
      document.getElementById("pm-close")!.addEventListener("click", close);
      modal.addEventListener("click", (e) => { if (e.target === modal) close(); });
      document.addEventListener("keydown", (e) => { if (!modal.classList.contains("hidden") && e.key === "Escape") close(); });
    })();
  </script>
</Base>
