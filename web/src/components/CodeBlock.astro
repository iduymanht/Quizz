---
// Terminal-style command block with a copy button. Single-line commands render
// inline with a `$` prompt; multi-line snippets render as a <pre>. Copy is wired
// globally in Base.astro via the delegated [data-copy] handler.
import Icon from "./Icon.astro";
interface Props { code: string; prompt?: boolean; class?: string; }
const { code, prompt = true, class: cls = "" } = Astro.props;
const multiline = code.includes("\n");
---
{multiline ? (
  <div class={`relative rounded-2xl border border-white/10 bg-ink px-4 py-3.5 shadow-soft ${cls}`}>
    <button
      type="button"
      data-copy={code}
      aria-label="Copy command"
      class="copy-btn absolute right-3 top-3 inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-white/10 px-2.5 py-1.5 text-xs font-semibold text-white/80 transition hover:bg-white/20"
    >
      <Icon name="copy" class="copy-i h-3.5 w-3.5" />
      <Icon name="check" class="check-i hidden h-3.5 w-3.5 text-mint-400" />
      <span class="copy-label">Copy</span>
    </button>
    <pre class="overflow-x-auto pr-20 font-mono text-sm leading-relaxed text-white/90"><code>{code}</code></pre>
  </div>
) : (
  <div class={`flex items-start gap-3 rounded-2xl border border-white/10 bg-ink px-4 py-3 font-mono text-sm shadow-soft ${cls}`}>
    {prompt && <span class="select-none pt-px text-brand-300">$</span>}
    <code class="min-w-0 flex-1 whitespace-pre-wrap break-words leading-relaxed text-white/90">{code}</code>
    <button
      type="button"
      data-copy={code}
      aria-label="Copy command"
      class="copy-btn inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-white/10 px-2.5 py-1.5 text-xs font-semibold text-white/80 transition hover:bg-white/20"
    >
      <Icon name="copy" class="copy-i h-3.5 w-3.5" />
      <Icon name="check" class="check-i hidden h-3.5 w-3.5 text-mint-400" />
      <span class="copy-label">Copy</span>
    </button>
  </div>
)}
