{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quiz",
  "version": "0.1.2",
  "identifier": "online.thenightwatcher.Quiz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Quiz Pet",
        "url": "index.html",
        "width": 600,
        "height": 460,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": false
      },
      {
        "label": "settings",
        "title": "Quiz — Cài đặt",
        "url": "settings.html",
        "width": 980,
        "height": 760,
        "minWidth": 620,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: ; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "billy",
    "homepage": "https://github.com/iduymanht/Quiz",
    "shortDescription": "Soạn câu hỏi trắc nghiệm.",
    "longDescription": "Quiz Builder — soạn câu hỏi trắc nghiệm bằng form hoặc nhập hàng loạt qua Markdown.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese", "Vietnamese"]
      }
    }
  },
  "plugins": {}
}
